<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SuspensionSim — Quarter-Car Dynamics</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;600;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg:        #0a0b0d;
    --bg2:       #0f1115;
    --bg3:       #151820;
    --panel:     #12151a;
    --border:    #1e2530;
    --amber:     #f5a623;
    --amber-dim: #7a5010;
    --green:     #3ddc84;
    --blue:      #4db8ff;
    --red:       #ff4d6d;
    --text:      #c8cdd6;
    --text-dim:  #545d6e;
    --mono:      'Share Tech Mono', monospace;
    --sans:      'Barlow Condensed', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 16px;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── GRID BACKGROUND ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  /* ── HEADER ── */
  header {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 36px;
    border-bottom: 1px solid var(--border);
    background: rgba(10,11,13,0.95);
    backdrop-filter: blur(8px);
  }

  .logo {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .logo-mark {
    font-family: var(--mono);
    font-size: 22px;
    color: var(--amber);
    letter-spacing: -1px;
  }
  .logo-sub {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .header-metrics {
    display: flex;
    gap: 32px;
  }
  .hm {
    text-align: right;
  }
  .hm-label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    font-family: var(--mono);
  }
  .hm-value {
    font-family: var(--mono);
    font-size: 18px;
    color: var(--amber);
  }
  .hm-value.good  { color: var(--green); }
  .hm-value.warn  { color: var(--amber); }
  .hm-value.bad   { color: var(--red);   }

  /* ── MAIN LAYOUT ── */
  main {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 300px 1fr;
    grid-template-rows: auto auto;
    gap: 0;
    min-height: calc(100vh - 65px);
  }

  /* ── SIDEBAR ── */
  aside {
    grid-row: 1 / 3;
    border-right: 1px solid var(--border);
    background: var(--panel);
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    overflow-y: auto;
  }

  .section-title {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--amber);
    border-bottom: 1px solid var(--amber-dim);
    padding-bottom: 6px;
    margin-bottom: 14px;
  }

  .param-group { }

  .param-row {
    margin-bottom: 18px;
  }

  .param-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6px;
  }

  .param-name {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text);
  }

  .param-val {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--amber);
  }

  .param-unit {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    margin-left: 3px;
  }

  input[type=range] {
    -webkit-appearance: none;
    width: 100%;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--amber);
    border: 2px solid var(--bg);
    box-shadow: 0 0 6px var(--amber);
    transition: box-shadow 0.2s;
  }
  input[type=range]:hover::-webkit-slider-thumb {
    box-shadow: 0 0 12px var(--amber);
  }
  input[type=range]::-webkit-slider-runnable-track {
    background: linear-gradient(90deg, var(--amber-dim), var(--border));
    height: 3px;
    border-radius: 2px;
  }

  /* Road Profile Selector */
  .road-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .road-btn {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1px;
    padding: 8px 6px;
    cursor: pointer;
    text-transform: uppercase;
    text-align: center;
    border-radius: 2px;
    transition: all 0.2s;
  }
  .road-btn:hover { border-color: var(--amber-dim); color: var(--text); }
  .road-btn.active { border-color: var(--amber); color: var(--amber); background: rgba(245,166,35,0.08); }

  /* System Status */
  .status-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .stat-box {
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 10px;
    border-radius: 2px;
  }
  .stat-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 4px;
  }
  .stat-value {
    font-family: var(--mono);
    font-size: 15px;
    color: var(--text);
  }
  .stat-value.amber { color: var(--amber); }
  .stat-value.green { color: var(--green); }
  .stat-value.red   { color: var(--red);   }

  .system-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 2px;
    padding: 4px 10px;
    border: 1px solid;
    border-radius: 2px;
    text-transform: uppercase;
    margin-top: 10px;
  }
  .badge-under  { color: var(--amber); border-color: var(--amber-dim); background: rgba(245,166,35,0.06); }
  .badge-crit   { color: var(--green); border-color: #1a6640;          background: rgba(61,220,132,0.06); }
  .badge-over   { color: var(--blue);  border-color: #1a4060;          background: rgba(77,184,255,0.06); }

  .run-btn {
    width: 100%;
    padding: 14px;
    background: var(--amber);
    color: var(--bg);
    border: none;
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.2s;
    font-weight: bold;
  }
  .run-btn:hover { background: #ffc048; box-shadow: 0 0 20px rgba(245,166,35,0.4); }
  .run-btn:active { transform: scale(0.98); }

  /* ── CANVAS AREA ── */
  .canvas-area {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .plot-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .plot-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .plot-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
  }

  .plot-title {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .plot-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
    box-shadow: 0 0 6px var(--amber);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  canvas {
    display: block;
    width: 100%;
  }

  /* ── ANIMATION PANEL ── */
  .anim-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .anim-controls {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-top: 1px solid var(--border);
    background: var(--bg2);
  }

  .ctrl-btn {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--mono);
    font-size: 11px;
    padding: 6px 14px;
    cursor: pointer;
    letter-spacing: 1px;
    border-radius: 2px;
    transition: all 0.15s;
  }
  .ctrl-btn:hover { border-color: var(--amber); color: var(--amber); }

  .speed-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    margin-left: auto;
  }

  select {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--mono);
    font-size: 11px;
    padding: 5px 8px;
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }
  select:focus { border-color: var(--amber); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ── FOOTER ── */
  footer {
    position: relative;
    z-index: 1;
    grid-column: 1 / -1;
    border-top: 1px solid var(--border);
    padding: 14px 36px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    background: var(--panel);
  }

  .comfort-bar {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .comfort-track {
    width: 160px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .comfort-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.4s, background 0.4s;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .canvas-area { animation: fadeIn 0.5s ease; }
</style>
</head>
<body>

<header>
  <div class="logo">
    <span class="logo-mark">SUSP<span style="color:var(--text-dim)">.</span>SIM</span>
    <span class="logo-sub">Quarter-Car Dynamics Engine</span>
  </div>
  <div class="header-metrics">
    <div class="hm">
      <div class="hm-label">Nat. Freq.</div>
      <div class="hm-value" id="hdr-wn">—</div>
    </div>
    <div class="hm">
      <div class="hm-label">Damp. Ratio ζ</div>
      <div class="hm-value" id="hdr-zeta">—</div>
    </div>
    <div class="hm">
      <div class="hm-label">Peak Accel.</div>
      <div class="hm-value" id="hdr-accel">—</div>
    </div>
    <div class="hm">
      <div class="hm-label">ISO 2631</div>
      <div class="hm-value" id="hdr-iso">—</div>
    </div>
  </div>
</header>

<main>
  <aside>
    <div class="param-group">
      <div class="section-title">System Parameters</div>

      <div class="param-row">
        <div class="param-header">
          <span class="param-name">Mass</span>
          <span><span class="param-val" id="val-m">250</span><span class="param-unit">kg</span></span>
        </div>
        <input type="range" id="sl-m" min="50" max="600" value="250" step="5"/>
      </div>

      <div class="param-row">
        <div class="param-header">
          <span class="param-name">Spring k</span>
          <span><span class="param-val" id="val-k">15000</span><span class="param-unit">N/m</span></span>
        </div>
        <input type="range" id="sl-k" min="2000" max="50000" value="15000" step="500"/>
      </div>

      <div class="param-row">
        <div class="param-header">
          <span class="param-name">Damping c</span>
          <span><span class="param-val" id="val-c">200</span><span class="param-unit">Ns/m</span></span>
        </div>
        <input type="range" id="sl-c" min="0" max="5000" value="200" step="50"/>
      </div>

      <div class="param-row">
        <div class="param-header">
          <span class="param-name">Bump Height</span>
          <span><span class="param-val" id="val-bump">5</span><span class="param-unit">cm</span></span>
        </div>
        <input type="range" id="sl-bump" min="1" max="40" value="5" step="0.5"/>
      </div>
    </div>

    <div>
      <div class="section-title">Road Profile</div>
      <div class="road-options">
        <button class="road-btn active" data-profile="bump">Flat Bump</button>
        <button class="road-btn" data-profile="sine">Sinusoidal</button>
        <button class="road-btn" data-profile="pothole">Pothole</button>
        <button class="road-btn" data-profile="random">Random</button>
      </div>
    </div>

    <div>
      <div class="section-title">System Status</div>
      <div class="status-grid">
        <div class="stat-box">
          <div class="stat-label">ωn (rad/s)</div>
          <div class="stat-value amber" id="st-wn">—</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">fn (Hz)</div>
          <div class="stat-value amber" id="st-fn">—</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Zeta ζ</div>
          <div class="stat-value" id="st-zeta">—</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Peak T-Bil</div>
          <div class="stat-value" id="st-peak">—</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Max Disp.</div>
          <div class="stat-value" id="st-disp">—</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Susp. Travel</div>
          <div class="stat-value" id="st-travel">—</div>
        </div>
      </div>
      <div id="st-badge" class="system-badge badge-under">Underdamped</div>
    </div>

    <button class="run-btn" id="run-btn">▶ Run Simulation</button>
  </aside>

  <div class="canvas-area">
    <div class="plot-row">
      <div class="plot-panel">
        <div class="plot-header">
          <span class="plot-title">Time Domain — Displacement</span>
          <div class="plot-indicator"></div>
        </div>
        <canvas id="cv-time" height="200"></canvas>
      </div>
      <div class="plot-panel">
        <div class="plot-header">
          <span class="plot-title">Body Acceleration (g)</span>
          <div class="plot-indicator" style="background:var(--red);box-shadow:0 0 6px var(--red)"></div>
        </div>
        <canvas id="cv-accel" height="200"></canvas>
      </div>
    </div>

    <div class="plot-row">
      <div class="plot-panel">
        <div class="plot-header">
          <span class="plot-title">Frequency Response — Transmissibility</span>
          <div class="plot-indicator" style="background:var(--blue);box-shadow:0 0 6px var(--blue)"></div>
        </div>
        <canvas id="cv-freq" height="200"></canvas>
      </div>
      <div class="anim-panel">
        <div class="plot-header">
          <span class="plot-title">Live Animation</span>
          <div class="plot-indicator" style="background:var(--green);box-shadow:0 0 6px var(--green)"></div>
        </div>
        <canvas id="cv-anim" height="170"></canvas>
        <div class="anim-controls">
          <button class="ctrl-btn" id="btn-play">⏸ Pause</button>
          <button class="ctrl-btn" id="btn-restart">↺ Restart</button>
          <span class="speed-label">Speed:
            <select id="sel-speed">
              <option value="0.5">0.5×</option>
              <option value="1" selected>1×</option>
              <option value="2">2×</option>
              <option value="4">4×</option>
            </select>
          </span>
        </div>
      </div>
    </div>
  </div>
</main>

<footer>
  <span>SUSPENSION.SIM — QUARTER-CAR MODEL / RK4 INTEGRATION</span>
  <div class="comfort-bar">
    <span>ISO 2631 COMFORT:</span>
    <div class="comfort-track">
      <div class="comfort-fill" id="comfort-fill" style="width:0%;background:var(--green)"></div>
    </div>
    <span id="comfort-label">—</span>
  </div>
  <span>© OBI UMEH</span>
</footer>

<script>
// ═══════════════════════════════════════════════
//  SIMULATION ENGINE
// ═══════════════════════════════════════════════

const DT = 0.002;
const T_END = 6.0;
const N = Math.floor(T_END / DT);

let simData = null;
let roadProfile = 'bump';
let animFrame = 0;
let animPlaying = true;
let animSpeed = 1;
let animRAF = null;
let randomRoad = null;

function getParams() {
  return {
    m:    +document.getElementById('sl-m').value,
    k:    +document.getElementById('sl-k').value,
    c:    +document.getElementById('sl-c').value,
    bump: +document.getElementById('sl-bump').value / 100
  };
}

function getRoad(profile, time, bump, rng) {
  switch(profile) {
    case 'bump':
      return (time > 0.5 && time < 0.6) ? bump : 0;
    case 'sine':
      return bump * 0.6 * Math.sin(2 * Math.PI * 1.5 * time) * (time < 4 ? 1 : 0);
    case 'pothole':
      return (time > 0.5 && time < 0.55) ? -bump * 1.2 :
             (time > 2.0 && time < 2.05) ? -bump * 0.8 : 0;
    case 'random':
      if (!rng) return 0;
      const idx = Math.floor(time / DT);
      return idx < rng.length ? rng[idx] : 0;
    default: return 0;
  }
}

function runSimulation() {
  const { m, k, c, bump } = getParams();

  // Pre-generate random road if needed
  let rng = null;
  if (roadProfile === 'random') {
    rng = new Float32Array(N);
    let rVal = 0;
    for (let i = 0; i < N; i++) {
      rVal += (Math.random() - 0.5) * 0.003;
      rVal = Math.max(-bump, Math.min(bump, rVal));
      rng[i] = rVal;
    }
    randomRoad = rng;
  }

  const t_arr = new Float32Array(N);
  const x_arr = new Float32Array(N);
  const v_arr = new Float32Array(N);
  const r_arr = new Float32Array(N);

  let x = 0, v = 0;

  for (let i = 0; i < N; i++) {
    const time = i * DT;
    const r = getRoad(roadProfile, time, bump, rng);

    function accel(xi, vi, ri) {
      return (-c * (vi - 0) - k * (xi - ri)) / m;
    }

    const k1v = accel(x, v, r);
    const k1x = v;
    const k2v = accel(x + 0.5*DT*k1x, v + 0.5*DT*k1v, r);
    const k2x = v + 0.5*DT*k1v;
    const k3v = accel(x + 0.5*DT*k2x, v + 0.5*DT*k2v, r);
    const k3x = v + 0.5*DT*k2v;
    const k4v = accel(x + DT*k3x, v + DT*k3v, r);
    const k4x = v + DT*k3v;

    x += (DT/6)*(k1x + 2*k2x + 2*k3x + k4x);
    v += (DT/6)*(k1v + 2*k2v + 2*k3v + k4v);

    t_arr[i] = time;
    x_arr[i] = x;
    v_arr[i] = v;
    r_arr[i] = r;
  }

  // Acceleration via finite difference
  const a_arr = new Float32Array(N);
  for (let i = 1; i < N-1; i++) {
    a_arr[i] = (v_arr[i+1] - v_arr[i-1]) / (2*DT) / 9.81;
  }

  // Frequency response (analytical)
  const freqs = new Float32Array(200);
  const H_mag = new Float32Array(200);
  for (let i = 0; i < 200; i++) {
    const omega = 0.1 + i * (60/200);
    freqs[i] = omega;
    const re = k - m*omega*omega;
    const im = c*omega;
    const num = Math.sqrt(k*k + (c*omega)*(c*omega));
    const den = Math.sqrt(re*re + im*im);
    H_mag[i] = num/den;
  }

  const omega_n = Math.sqrt(k/m);
  const zeta = c / (2*Math.sqrt(k*m));
  const peakDisp = Math.max(...x_arr.map(Math.abs));
  const suspTravel = Math.max(...x_arr.map((xi,i) => Math.abs(xi - r_arr[i])));
  const peakAccelG = Math.max(...a_arr.map(Math.abs));
  const peakT = Math.max(...H_mag);

  simData = { t_arr, x_arr, v_arr, r_arr, a_arr, freqs, H_mag,
              omega_n, zeta, peakDisp, suspTravel, peakAccelG, peakT, m, k, c };

  return simData;
}

// ═══════════════════════════════════════════════
//  CANVAS DRAWING UTILITIES
// ═══════════════════════════════════════════════

function getCtx(id) {
  const cv = document.getElementById(id);
  cv.width = cv.offsetWidth * window.devicePixelRatio;
  cv.height = cv.offsetHeight * window.devicePixelRatio;
  const ctx = cv.getContext('2d');
  ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  return { ctx, w: cv.offsetWidth, h: cv.offsetHeight };
}

const BG     = '#12151a';
const GRID   = '#1a1f28';
const AMBER  = '#f5a623';
const GREEN  = '#3ddc84';
const BLUE   = '#4db8ff';
const RED    = '#ff4d6d';
const DIMTXT = '#545d6e';
const TEXT   = '#c8cdd6';

function drawGrid(ctx, w, h, nx=8, ny=5) {
  ctx.strokeStyle = GRID;
  ctx.lineWidth = 1;
  for (let i=0; i<=nx; i++) {
    const x = (i/nx)*w;
    ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,h); ctx.stroke();
  }
  for (let i=0; i<=ny; i++) {
    const y = (i/ny)*h;
    ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(w,y); ctx.stroke();
  }
}

function drawAxis(ctx, w, h, pad) {
  ctx.strokeStyle = '#2a3040';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad,pad); ctx.lineTo(pad,h-pad); ctx.lineTo(w-pad,h-pad); ctx.stroke();
}

function plotLine(ctx, data, n, w, h, pad, minV, maxV, color, lw=1.5) {
  const range = maxV - minV || 1;
  ctx.strokeStyle = color;
  ctx.lineWidth = lw;
  ctx.beginPath();
  for (let i=0; i<n; i++) {
    const px = pad + (i/(n-1))*(w-2*pad);
    const py = (h-pad) - ((data[i]-minV)/range)*(h-2*pad);
    i===0 ? ctx.moveTo(px,py) : ctx.lineTo(px,py);
  }
  ctx.stroke();
}

function labelY(ctx, val, y, pad, color=DIMTXT) {
  ctx.fillStyle = color;
  ctx.font = '9px Share Tech Mono';
  ctx.textAlign = 'right';
  ctx.fillText(val, pad-4, y+3);
}
function labelX(ctx, val, x, h, pad) {
  ctx.fillStyle = DIMTXT;
  ctx.font = '9px Share Tech Mono';
  ctx.textAlign = 'center';
  ctx.fillText(val, x, h-2);
}

// ── TIME DOMAIN PLOT ──
function drawTimePlot(d) {
  const { ctx, w, h } = getCtx('cv-time');
  const pad = 38;
  ctx.fillStyle = BG; ctx.fillRect(0,0,w,h);
  drawGrid(ctx,w,h);

  const minV = Math.min(...d.x_arr, ...d.r_arr) * 100 - 0.5;
  const maxV = Math.max(...d.x_arr, ...d.r_arr) * 100 + 0.5;

  // Road fill
  ctx.fillStyle = 'rgba(77,184,255,0.05)';
  const range = maxV-minV||1;
  ctx.beginPath();
  for (let i=0; i<N; i++) {
    const px = pad + (i/(N-1))*(w-2*pad);
    const py = (h-pad) - ((d.r_arr[i]*100-minV)/range)*(h-2*pad);
    i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
  }
  ctx.lineTo(pad+(w-2*pad), h-pad); ctx.lineTo(pad, h-pad); ctx.closePath(); ctx.fill();

  plotLine(ctx, Array.from(d.r_arr).map(v=>v*100), N, w, h, pad, minV, maxV, BLUE, 1.2);

  // Body displacement fill under curve
  ctx.fillStyle = 'rgba(245,166,35,0.07)';
  ctx.beginPath();
  for (let i=0; i<N; i++) {
    const px = pad + (i/(N-1))*(w-2*pad);
    const zero = (h-pad)-((0-minV)/range)*(h-2*pad);
    const py   = (h-pad)-((d.x_arr[i]*100-minV)/range)*(h-2*pad);
    i===0?ctx.moveTo(px,zero):null;
    ctx.lineTo(px,py);
  }
  ctx.lineTo(pad+(w-2*pad), (h-pad)-((0-minV)/range)*(h-2*pad));
  ctx.closePath(); ctx.fill();

  plotLine(ctx, Array.from(d.x_arr).map(v=>v*100), N, w, h, pad, minV, maxV, AMBER, 2);

  // Zero line
  const zeroY = (h-pad)-((0-minV)/range)*(h-2*pad);
  ctx.strokeStyle='#2a3040'; ctx.lineWidth=1; ctx.setLineDash([4,4]);
  ctx.beginPath(); ctx.moveTo(pad,zeroY); ctx.lineTo(w-pad,zeroY); ctx.stroke();
  ctx.setLineDash([]);

  // Labels
  for(let i=0;i<=5;i++){
    const v = minV + i*(maxV-minV)/5;
    labelY(ctx, v.toFixed(1), (h-pad)-(i/5)*(h-2*pad), pad);
  }
  for(let i=0;i<=6;i++){
    labelX(ctx, (i*(T_END/6)).toFixed(1)+'s', pad+i*(w-2*pad)/6, h, pad);
  }

  // Legend
  ctx.font = '9px Share Tech Mono';
  ctx.fillStyle = AMBER; ctx.textAlign='left'; ctx.fillText('● BODY', w-90, 18);
  ctx.fillStyle = BLUE;  ctx.fillText('● ROAD', w-90, 30);
  ctx.fillStyle = DIMTXT; ctx.textAlign='left'; ctx.fillText('cm', pad+2, 14);
}

// ── ACCELERATION PLOT ──
function drawAccelPlot(d) {
  const { ctx, w, h } = getCtx('cv-accel');
  const pad = 38;
  ctx.fillStyle = BG; ctx.fillRect(0,0,w,h);
  drawGrid(ctx,w,h);

  const maxA = Math.max(Math.max(...d.a_arr.map(Math.abs)), 0.1);
  const minV = -maxA*1.2, maxV = maxA*1.2;

  // ISO threshold fills
  const iso1g = 0.315, iso2g = 0.63;
  const range = maxV-minV;
  const y1t = (h-pad)-((iso1g-minV)/range)*(h-2*pad);
  const y1b = (h-pad)-((-iso1g-minV)/range)*(h-2*pad);
  ctx.fillStyle='rgba(61,220,132,0.06)';
  ctx.fillRect(pad, y1t, w-2*pad, y1b-y1t);

  const y2t=(h-pad)-((iso2g-minV)/range)*(h-2*pad);
  const y2b=(h-pad)-((-iso2g-minV)/range)*(h-2*pad);
  ctx.fillStyle='rgba(245,166,35,0.05)';
  ctx.fillRect(pad,y2t,w-2*pad,y1t-y2t);
  ctx.fillRect(pad,y1b,w-2*pad,y2b-y1b);

  // ISO lines
  [iso1g,-iso1g,iso2g,-iso2g].forEach((v,i)=>{
    const y = (h-pad)-((v-minV)/range)*(h-2*pad);
    ctx.strokeStyle=i<2?GREEN:AMBER; ctx.lineWidth=0.8; ctx.setLineDash([3,5]);
    ctx.beginPath(); ctx.moveTo(pad,y); ctx.lineTo(w-pad,y); ctx.stroke();
  });
  ctx.setLineDash([]);

  plotLine(ctx, Array.from(d.a_arr), N, w, h, pad, minV, maxV, RED, 1.5);

  for(let i=0;i<=5;i++){
    const v=minV+i*(maxV-minV)/5;
    labelY(ctx,v.toFixed(2),(h-pad)-(i/5)*(h-2*pad),pad);
  }
  for(let i=0;i<=6;i++){
    labelX(ctx,(i*(T_END/6)).toFixed(1)+'s',pad+i*(w-2*pad)/6,h,pad);
  }
  ctx.font='9px Share Tech Mono'; ctx.fillStyle=DIMTXT;
  ctx.textAlign='left'; ctx.fillText('g', pad+2, 14);
  ctx.fillStyle=GREEN; ctx.fillText('— ISO comfortable', w-130, 14);
}

// ── FREQUENCY RESPONSE ──
function drawFreqPlot(d) {
  const { ctx, w, h } = getCtx('cv-freq');
  const pad = 42;
  ctx.fillStyle = BG; ctx.fillRect(0,0,w,h);
  drawGrid(ctx,w,h);

  const logMin = Math.log10(0.01);
  const logMax = Math.log10(20);
  const logRange = logMax - logMin;
  const freqMax = 60;
  const n = d.freqs.length;

  ctx.strokeStyle = BLUE;
  ctx.lineWidth = 2;
  ctx.beginPath();
  for (let i=0; i<n; i++) {
    const px = pad + (d.freqs[i]/freqMax)*(w-2*pad);
    const logV = Math.log10(Math.max(d.H_mag[i], 0.01));
    const py = (h-pad) - ((logV-logMin)/logRange)*(h-2*pad);
    i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
  }
  ctx.stroke();

  // Unity line
  const unityY = (h-pad) - ((0-logMin)/logRange)*(h-2*pad);
  ctx.strokeStyle='#2a3040'; ctx.lineWidth=1; ctx.setLineDash([4,4]);
  ctx.beginPath(); ctx.moveTo(pad,unityY); ctx.lineTo(w-pad,unityY); ctx.stroke();
  ctx.setLineDash([]);

  // Resonance marker
  const peakIdx = Array.from(d.H_mag).indexOf(Math.max(...d.H_mag));
  const resonX = pad+(d.freqs[peakIdx]/freqMax)*(w-2*pad);
  const resonLogV = Math.log10(Math.max(d.H_mag[peakIdx],0.01));
  const resonY = (h-pad)-((resonLogV-logMin)/logRange)*(h-2*pad);
  ctx.strokeStyle = AMBER; ctx.lineWidth=1; ctx.setLineDash([3,4]);
  ctx.beginPath(); ctx.moveTo(resonX,pad); ctx.lineTo(resonX,h-pad); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle=AMBER; ctx.beginPath(); ctx.arc(resonX,resonY,4,0,Math.PI*2); ctx.fill();

  ctx.font='9px Share Tech Mono'; ctx.fillStyle=AMBER; ctx.textAlign='left';
  ctx.fillText(`ωn=${d.omega_n.toFixed(2)}`, resonX+6, resonY-6);

  // Y labels (log)
  [0.01,0.1,1,10].forEach(v=>{
    const logV=Math.log10(v);
    const y=(h-pad)-((logV-logMin)/logRange)*(h-2*pad);
    if(y>pad&&y<h-pad){
      ctx.fillStyle=DIMTXT; ctx.font='9px Share Tech Mono';
      ctx.textAlign='right'; ctx.fillText(v+'×',pad-4,y+3);
    }
  });

  [0,10,20,30,40,50,60].forEach(f=>{
    labelX(ctx,f,pad+(f/freqMax)*(w-2*pad),h,pad);
  });

  ctx.fillStyle=DIMTXT; ctx.font='9px Share Tech Mono';
  ctx.textAlign='left'; ctx.fillText('rad/s',w-40,h-2);
}

// ── ANIMATION ──
function makeZigzag(x0, yBot, yTop, coils=6, amp=18) {
  const pts = [];
  const steps = coils*2+2;
  for(let i=0;i<steps;i++){
    const t=i/(steps-1);
    const y=yBot+(yTop-yBot)*t;
    const x=i===0||i===steps-1?x0:x0+(i%2===1?amp:-amp);
    pts.push([x,y]);
  }
  return pts;
}

function drawAnim(d, frame) {
  const cv = document.getElementById('cv-anim');
  cv.width  = cv.offsetWidth  * window.devicePixelRatio;
  cv.height = cv.offsetHeight * window.devicePixelRatio;
  const ctx = cv.getContext('2d');
  ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  const W = cv.offsetWidth, H = cv.offsetHeight;

  ctx.fillStyle = BG; ctx.fillRect(0,0,W,H);

  // Grid
  ctx.strokeStyle = GRID; ctx.lineWidth=1;
  for(let i=0;i<8;i++){
    const x=i*(W/8); ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();
  }
  for(let i=0;i<6;i++){
    const y=i*(H/6); ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();
  }

  const fi = Math.min(frame, N-1);
  const xCar = d.x_arr[fi] * 600;
  const rVal  = d.r_arr[fi] * 600;

  const CX = W/2;
  const BASE_Y = H - 40;
  const WHEEL_R = 22;

  // Road surface
  const roadY = BASE_Y - rVal;
  ctx.fillStyle = '#1a2235';
  ctx.fillRect(0, roadY, W, H - roadY);
  ctx.strokeStyle = BLUE; ctx.lineWidth=2;
  ctx.beginPath(); ctx.moveTo(0,roadY); ctx.lineTo(W,roadY); ctx.stroke();

  // Road markings
  ctx.strokeStyle='rgba(77,184,255,0.2)'; ctx.lineWidth=1; ctx.setLineDash([20,20]);
  ctx.beginPath(); ctx.moveTo(0,roadY+10); ctx.lineTo(W,roadY+10); ctx.stroke();
  ctx.setLineDash([]);

  // Wheel
  const WHEEL_Y = roadY - WHEEL_R;
  const grad = ctx.createRadialGradient(CX-6,WHEEL_Y-6,3,CX,WHEEL_Y,WHEEL_R);
  grad.addColorStop(0,'#5a5a6a'); grad.addColorStop(1,'#2a2a3a');
  ctx.fillStyle=grad;
  ctx.beginPath(); ctx.arc(CX, WHEEL_Y, WHEEL_R, 0, Math.PI*2); ctx.fill();
  ctx.strokeStyle='#3a3a4a'; ctx.lineWidth=3;
  ctx.beginPath(); ctx.arc(CX, WHEEL_Y, WHEEL_R, 0, Math.PI*2); ctx.stroke();
  ctx.fillStyle='#3a3a4a';
  ctx.beginPath(); ctx.arc(CX, WHEEL_Y, 8, 0, Math.PI*2); ctx.fill();

  // Car body
  const CAR_BOTTOM = BASE_Y - 80 - xCar;
  const CAR_H = 40, CAR_W = 160;
  const carGrad = ctx.createLinearGradient(CX,CAR_BOTTOM,CX,CAR_BOTTOM+CAR_H);
  carGrad.addColorStop(0,'#cc3333'); carGrad.addColorStop(1,'#882222');
  ctx.fillStyle=carGrad;
  ctx.beginPath();
  ctx.roundRect(CX-CAR_W/2, CAR_BOTTOM, CAR_W, CAR_H, 6);
  ctx.fill();
  ctx.strokeStyle='rgba(255,100,100,0.4)'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.roundRect(CX-CAR_W/2,CAR_BOTTOM,CAR_W,CAR_H,6); ctx.stroke();

  // Windshield
  ctx.fillStyle='rgba(100,180,255,0.25)';
  ctx.beginPath();
  ctx.roundRect(CX-50,CAR_BOTTOM-18,100,20,3);
  ctx.fill();

  // Spring (zigzag)
  const springTop = CAR_BOTTOM + CAR_H;
  const springBot = WHEEL_Y - WHEEL_R + 4;
  const zz = makeZigzag(CX-30, springBot, springTop, 5, 14);
  ctx.strokeStyle=AMBER; ctx.lineWidth=2; ctx.lineJoin='round';
  ctx.beginPath();
  zz.forEach(([x,y],i) => i===0?ctx.moveTo(x,y):ctx.lineTo(x,y));
  ctx.stroke();

  // Damper
  const dX = CX+30;
  ctx.strokeStyle=BLUE; ctx.lineWidth=3;
  ctx.beginPath(); ctx.moveTo(dX, springBot); ctx.lineTo(dX, springTop); ctx.stroke();
  const midY=(springBot+springTop)/2;
  ctx.fillStyle='rgba(77,184,255,0.3)';
  ctx.fillRect(dX-8, midY-12, 16, 24);
  ctx.strokeStyle=BLUE; ctx.lineWidth=1;
  ctx.strokeRect(dX-8,midY-12,16,24);

  // Time & displacement readout
  ctx.font='10px Share Tech Mono';
  ctx.fillStyle=AMBER; ctx.textAlign='left';
  ctx.fillText(`t = ${(fi*DT).toFixed(2)}s`, 10, 18);
  ctx.fillStyle=TEXT;
  ctx.fillText(`x = ${(d.x_arr[fi]*100).toFixed(2)}cm`, 10, 32);
  ctx.fillText(`r = ${(d.r_arr[fi]*100).toFixed(2)}cm`, 10, 46);
}

// ═══════════════════════════════════════════════
//  UI UPDATE
// ═══════════════════════════════════════════════

function updateHeader(d) {
  const zetaEl = document.getElementById('hdr-zeta');
  const z = d.zeta;
  zetaEl.textContent = z.toFixed(3);
  zetaEl.className = 'hm-value ' + (z<0.1?'bad':z<0.25?'warn':'good');

  document.getElementById('hdr-wn').textContent = d.omega_n.toFixed(2)+' rad/s';

  const aEl = document.getElementById('hdr-accel');
  aEl.textContent = d.peakAccelG.toFixed(3)+'g';
  aEl.className = 'hm-value '+(d.peakAccelG<0.315?'good':d.peakAccelG<0.63?'warn':'bad');

  const isoEl = document.getElementById('hdr-iso');
  const comfort = d.peakAccelG < 0.315 ? 'COMFORTABLE'
                : d.peakAccelG < 0.63  ? 'MODERATE'
                : d.peakAccelG < 1.0   ? 'UNCOMFORTABLE' : 'SEVERE';
  isoEl.textContent = comfort;
  isoEl.className = 'hm-value '+(d.peakAccelG<0.315?'good':d.peakAccelG<0.63?'warn':'bad');
}

function updateSidebar(d) {
  document.getElementById('st-wn').textContent    = d.omega_n.toFixed(3);
  document.getElementById('st-fn').textContent    = (d.omega_n/(2*Math.PI)).toFixed(3);
  document.getElementById('st-disp').textContent  = (d.peakDisp*100).toFixed(2)+'cm';
  document.getElementById('st-travel').textContent= (d.suspTravel*100).toFixed(2)+'cm';
  document.getElementById('st-peak').textContent  = d.peakT.toFixed(2)+'×';

  const zetaEl = document.getElementById('st-zeta');
  zetaEl.textContent = d.zeta.toFixed(4);
  zetaEl.className = 'stat-value '+(d.zeta<0.1?'red':d.zeta<0.3?'amber':'green');

  const badge = document.getElementById('st-badge');
  if(d.zeta < 1){ badge.textContent='Underdamped'; badge.className='system-badge badge-under'; }
  else if(d.zeta===1){ badge.textContent='Critically Damped'; badge.className='system-badge badge-crit'; }
  else { badge.textContent='Overdamped'; badge.className='system-badge badge-over'; }

  // Comfort bar
  const pct = Math.min(d.peakAccelG/1.5*100,100);
  const fill = document.getElementById('comfort-fill');
  fill.style.width = pct+'%';
  fill.style.background = d.peakAccelG<0.315?GREEN:d.peakAccelG<0.63?AMBER:RED;
  document.getElementById('comfort-label').textContent =
    d.peakAccelG<0.315?'OK':d.peakAccelG<0.63?'MODERATE':'POOR';
}

function updateSliderDisplays() {
  document.getElementById('val-m').textContent    = document.getElementById('sl-m').value;
  document.getElementById('val-k').textContent    = document.getElementById('sl-k').value;
  document.getElementById('val-c').textContent    = document.getElementById('sl-c').value;
  document.getElementById('val-bump').textContent = document.getElementById('sl-bump').value;
}

// ═══════════════════════════════════════════════
//  ANIMATION LOOP
// ═══════════════════════════════════════════════

function startAnimation() {
  if(animRAF) cancelAnimationFrame(animRAF);
  let last = null;
  const ANIM_DT = DT * 1000;

  function tick(ts) {
    if(!animPlaying){ animRAF=requestAnimationFrame(tick); return; }
    if(last!==null){
      const elapsed = (ts-last) * animSpeed;
      animFrame += Math.floor(elapsed / ANIM_DT);
      if(animFrame >= N) animFrame = 0;
    }
    last = ts;
    if(simData) drawAnim(simData, animFrame);
    animRAF = requestAnimationFrame(tick);
  }
  animRAF = requestAnimationFrame(tick);
}

// ═══════════════════════════════════════════════
//  EVENT WIRING
// ═══════════════════════════════════════════════

function runAndDraw() {
  const d = runSimulation();
  drawTimePlot(d);
  drawAccelPlot(d);
  drawFreqPlot(d);
  updateHeader(d);
  updateSidebar(d);
  animFrame = 0;
}

document.getElementById('run-btn').addEventListener('click', runAndDraw);

['sl-m','sl-k','sl-c','sl-bump'].forEach(id=>{
  document.getElementById(id).addEventListener('input', ()=>{
    updateSliderDisplays();
    // Live update header metrics without full redraw
    const {m,k,c} = getParams();
    const omega_n = Math.sqrt(k/m);
    const zeta    = c/(2*Math.sqrt(k*m));
    document.getElementById('hdr-wn').textContent   = omega_n.toFixed(2)+' rad/s';
    document.getElementById('hdr-zeta').textContent = zeta.toFixed(3);
    document.getElementById('st-wn').textContent    = omega_n.toFixed(3);
    document.getElementById('st-fn').textContent    = (omega_n/(2*Math.PI)).toFixed(3);
    document.getElementById('st-zeta').textContent  = zeta.toFixed(4);
  });
});

document.querySelectorAll('.road-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('.road-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    roadProfile = btn.dataset.profile;
  });
});

document.getElementById('btn-play').addEventListener('click', ()=>{
  animPlaying = !animPlaying;
  document.getElementById('btn-play').textContent = animPlaying ? '⏸ Pause' : '▶ Play';
});

document.getElementById('btn-restart').addEventListener('click', ()=>{
  animFrame = 0;
});

document.getElementById('sel-speed').addEventListener('change', e=>{
  animSpeed = +e.target.value;
});

window.addEventListener('resize', ()=>{
  if(simData){ drawTimePlot(simData); drawAccelPlot(simData); drawFreqPlot(simData); }
});

// ── INIT ──
updateSliderDisplays();
runAndDraw();
startAnimation();
</script>
